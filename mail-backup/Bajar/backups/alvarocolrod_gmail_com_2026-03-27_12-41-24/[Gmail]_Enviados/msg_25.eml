<?php

class MailDownloader {

    private $imap;
    private $progressFile;

    public function __construct($imapClient) {
        $this->imap =3D $imapClient;
    }

    /**
     * Establece el archivo donde se escribir=C3=A1 el progreso para la bar=
ra
real
     */
    public function setProgressFile($file) {
        $this->progressFile =3D $file;
    }

    /**
     * Funci=C3=B3n interna para actualizar el archivo .txt de progreso
     */
    private function updateRealProgress($percent, $status) {
        if ($this->progressFile) {
            file_put_contents($this->progressFile, json_encode([
                'percent' =3D> $percent,
                'status' =3D> $status
            ]));
        }
    }

    public function downloadAll($folders, $basePath) {
        $limit =3D 500; // L=C3=ADmite de correos por carpeta

        // 1. Contar mensajes totales para el c=C3=A1lculo del porcentaje
        // (Consideramos el l=C3=ADmite en el conteo para que la barra sea
precisa)
        $totalGlobal =3D 0;
        foreach ($folders as $folder) {
            $this->imap->openFolder($folder);
            $count =3D $this->imap->getMessageCount();
            $totalGlobal +=3D ($count > $limit) ? $limit : $count;
        }

        if ($totalGlobal =3D=3D 0) $totalGlobal =3D 1;
        $processed =3D 0;

        // 2. Proceso de descarga
        foreach ($folders as $folder) {
            $decodedFolder =3D
imap_utf7_decode(str_replace($this->getMailboxPrefix(), '', $folder));
            $safeFolder =3D str_replace(['/', '\\'], '_', $decodedFolder);
            $folderPath =3D $basePath . '/' . $safeFolder;

            if (!file_exists($folderPath)) {
                mkdir($folderPath, 0777, true);
            }

            $this->imap->openFolder($folder);
            $messageCount =3D $this->imap->getMessageCount();

            // Calculamos desde d=C3=B3nde empezar para obtener los =C3=BAl=
timos 500
            // IMAP cuenta de 1 a N, siendo N el m=C3=A1s reciente.
            $start =3D ($messageCount - $limit > 0) ? ($messageCount - $lim=
it
+ 1) : 1;

            // Recorremos desde el m=C3=A1s reciente hacia atr=C3=A1s
            for ($i =3D $messageCount; $i >=3D $start; $i--) {

                $header =3D $this->imap->getHeaders($i);
                $body =3D $this->imap->getBody($i);
                $emailContent =3D $header . "\n" . $body;

                // Guardamos el archivo .eml
                file_put_contents($folderPath . "/msg_$i.eml",
$emailContent);

                $processed++;

                // Actualizamos el progreso en el archivo .txt (reservamos
el 10% final para el ZIP)
                $percent =3D round(($processed / $totalGlobal) * 90);
                $this->updateRealProgress($percent, "Descargando:
$processed de $totalGlobal correos...");
            }
        }
    }

    private function getMailboxPrefix() {
        $folders =3D $this->imap->getFolders();
        if (isset($folders[0])) {
            return strstr($folders[0], '}', true) . '}';
        }
        return '';
    }
}

